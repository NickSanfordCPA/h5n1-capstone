# Copy to .env (which is gitignored) and fill in. NEVER commit the real .env.
# Share the real values through the team password manager, not git or Slack.

# --- Postgres (reached via the Cloud SQL Auth Proxy on localhost) ---
# If you already run Postgres locally it owns 5432, and the proxy will fail with
# "socket ... forbidden by its access permissions" (Windows) instead of a clear
# "address in use". Pick a free port here and pass the same one to --port.
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=h5n1
DB_USER=h5n1_app
DB_PASSWORD=

# --- GCP ---
GCP_PROJECT=
GCS_RAW_BUCKET=
GCS_SOCIAL_BUCKET=
# Cloud SQL instance connection name: PROJECT:REGION:INSTANCE (used by the proxy).
CLOUD_SQL_INSTANCE=

# Local dev auth: prefer `gcloud auth application-default login` over a key file.
# Only set this if using the service-account key (jobs/CI); it is gitignored.
GOOGLE_APPLICATION_CREDENTIALS=
